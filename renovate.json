{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "docker:enableMajor",
        ":semanticCommits"
    ],
    "kubernetes": {
        "fileMatch": [
            "\\.yaml$"
        ]
    },
    "automerge": false,
    "timezone": "Europe/Berlin",
    "schedule": [
        "before 9am on Monday"
    ],
    "dependencyDashboardTitle": "Renovate Dashboard 🤖",
    "packageRules": [
        {
            "description": "Group n8n main + worker (must stay in sync)",
            "matchPackageNames": [
                "docker.n8n.io/n8nio/n8n"
            ],
            "groupName": "n8n"
        },
        {
            "description": "Database major versions need migration planning",
            "matchPackageNames": [
                "postgres",
                "redis"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "labels": [
                "database",
                "breaking"
            ]
        },
        {
            "description": "Label all major updates for careful review",
            "matchUpdateTypes": [
                "major"
            ],
            "labels": [
                "major"
            ]
        }
    ]
}
